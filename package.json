{
  "name": "jotas-brain",
  "version": "1.0.0",
  "description": "Jota's Brain — Prospecção de Criadores",
  "main": "main.js",
  "author": "Jota's Brain",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jotasbrain.prospeccao",
    "productName": "Jota's Brain",
    "files": [
      "index.html",
      "main.js",
      "icon.png"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jota's Brain"
    },
    "portable": {
      "artifactName": "JotasBrain-Portable.exe"
    }
  }
}
